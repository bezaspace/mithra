#!/usr/bin/env bash
set -euo pipefail

SERVICE_ID="srv-d6rmutua2pns73fqs8a0"
CONFIG_PATH="${RENDER_CLI_CONFIG_PATH:-$HOME/.render/cli.yaml}"
ACTION="${1:-status}"

usage() {
  cat <<'EOF'
Usage:
  backend-control off
  backend-control on
  backend-control status

Shortcuts:
  boff     Suspend the Render backend
  bon      Resume the Render backend
  bstatus  Show backend status
EOF
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf '[backend-control] Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

extract_render_api_key() {
  python - "$CONFIG_PATH" <<'PY'
from pathlib import Path
import sys

config_path = Path(sys.argv[1]).expanduser()
if not config_path.exists():
    sys.exit(1)

api_section = False
for raw_line in config_path.read_text(encoding="utf-8").splitlines():
    stripped = raw_line.strip()
    if stripped == "api:":
        api_section = True
        continue
    if api_section:
        if raw_line and not raw_line.startswith((" ", "\t")):
            break
        if stripped.startswith("key:"):
            value = stripped.split(":", 1)[1].strip()
            if value:
                print(value)
                sys.exit(0)
            break
sys.exit(1)
PY
}

render_api_call() {
  local method="$1"
  local path="$2"
  local token

  token="${RENDER_API_KEY:-}"
  if [ -z "$token" ]; then
    if ! token="$(extract_render_api_key)"; then
      printf '[backend-control] Could not find a Render API key. Run `render login` first.\n' >&2
      exit 1
    fi
  fi

  curl --silent --show-error --fail \
    --request "$method" \
    --header "Accept: application/json" \
    --header "Authorization: Bearer $token" \
    "https://api.render.com/v1$path"
}

show_status() {
  require_command curl

  local response
  response="$(render_api_call GET "/services/$SERVICE_ID")"

  BACKEND_CONTROL_RESPONSE="$response" python - <<'PY'
import json
import os

service = json.loads(os.environ["BACKEND_CONTROL_RESPONSE"])
details = service.get("serviceDetails", {})
status = service.get("suspended", "unknown")
maintenance = details.get("maintenanceMode", {}).get("enabled", False)
url = details.get("url", "unknown")

print(f"Backend: {service.get('name', 'unknown')} ({service.get('id', 'unknown')})")
print(f"State: {status}")
print(f"Maintenance mode: {'on' if maintenance else 'off'}")
print(f"URL: {url}")
PY
}

suspend_backend() {
  require_command curl
  printf '[backend-control] Suspending backend...\n'
  render_api_call POST "/services/$SERVICE_ID/suspend" >/dev/null
  printf '[backend-control] Suspend requested.\n'
  show_status
}

resume_backend() {
  require_command curl
  printf '[backend-control] Resuming backend...\n'
  render_api_call POST "/services/$SERVICE_ID/resume" >/dev/null
  printf '[backend-control] Resume requested.\n'
  show_status
}

case "$ACTION" in
  off)
    suspend_backend
    ;;
  on)
    resume_backend
    ;;
  status)
    show_status
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
